<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root-pane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bais.controllers.DashboardController">

    <!-- TOP HEADER -->
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT">
            <HBox styleClass="header-logo-section" alignment="CENTER_LEFT" spacing="10">
                <Label text="🎓" styleClass="header-logo-icon" />
                <VBox spacing="1">
                    <Label fx:id="headerTitle"    text="Akademické Info"   styleClass="header-main-title" />
                    <Label fx:id="headerSubtitle" text="Študentský Portál" styleClass="header-main-subtitle" />
                </VBox>
            </HBox>
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="search-container">
                <TextField fx:id="searchField" promptText="Hľadať AIS Desktop..."
                           styleClass="search-bar" maxWidth="800" />
            </HBox>
            <HBox styleClass="header-actions" alignment="CENTER_RIGHT" spacing="4">
                <StackPane fx:id="notificationsAction" onMouseClicked="#handleNotifications" styleClass="header-action-item">
                    <Label text="🔔" styleClass="notification-icon" />
                    <Label text="0"  fx:id="notifBadge" styleClass="notification-badge" StackPane.alignment="BOTTOM_RIGHT" />
                </StackPane>
                <Label fx:id="calendarAction" text="📅" styleClass="help-icon" onMouseClicked="#handleCalendar" />
                <Button fx:id="darkModeToggle" text="🌙"
                        styleClass="dark-mode-toggle" onAction="#toggleDarkMode" />
            </HBox>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar">

            <Region styleClass="sidebar-separator" />

            <!-- Main nav -->
            <VBox VBox.vgrow="ALWAYS" spacing="0">
                <!-- Dashboard / Prehľad -->
                <VBox fx:id="dashboardItem" styleClass="nav-item,nav-item-active" onMouseClicked="#handleDashboard">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="🏠"  styleClass="nav-icon" /><Label fx:id="navDashboard" text="Prehľad"    styleClass="nav-label" />
                    </HBox>
                </VBox>
                <!-- Grades / Admin Panel -->
                <VBox fx:id="gradesItem" styleClass="nav-item" onMouseClicked="#handleGrades">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📊" styleClass="nav-icon" /><Label fx:id="navGrades"    text="Hodnotenia" styleClass="nav-label" />
                    </HBox>
                </VBox>
                <!-- Calendar -->
                <VBox fx:id="calendarItem" styleClass="nav-item" onMouseClicked="#handleCalendar">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📅" styleClass="nav-icon" /><Label fx:id="navCalendar"  text="Kalendár"   styleClass="nav-label" />
                    </HBox>
                </VBox>
                <!-- Progress (student only) -->
                <VBox fx:id="progressItem" styleClass="nav-item" onMouseClicked="#handleProgress">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="🎓" styleClass="nav-icon" /><Label fx:id="navProgress"  text="Progres"    styleClass="nav-label" />
                    </HBox>
                </VBox>
                <!-- Assignments (student only) -->
                <VBox fx:id="algebraItem" styleClass="nav-item" onMouseClicked="#handleAlgebra">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📐" styleClass="nav-icon" /><Label fx:id="navAlgebra"   text="Odovzdanie" styleClass="nav-label" />
                    </HBox>
                </VBox>

                <!-- ── ADMIN-ONLY nav items (hidden for non-admin) ── -->
                <VBox fx:id="adminSubjectsItem" styleClass="nav-item" onMouseClicked="#handleAdminSubjects" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📚" styleClass="nav-icon" /><Label fx:id="navAdminSubjects" text="Predmety" styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="adminGuarantorsItem" styleClass="nav-item" onMouseClicked="#handleAdminGuarantors" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="🔗" styleClass="nav-icon" /><Label fx:id="navAdminGuarantors" text="Garanti" styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="adminCreateTeacherItem" styleClass="nav-item" onMouseClicked="#handleAdminCreateTeacher" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="👤" styleClass="nav-icon" /><Label fx:id="navAdminCreateTeacher" text="Vytvoriť učiteľa" styleClass="nav-label" />
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- Bottom -->
            <VBox styleClass="sidebar-bottom" spacing="0">
                <VBox fx:id="settingsItem" styleClass="nav-item" onMouseClicked="#handleSettings">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="⚙" styleClass="nav-icon" /><Label fx:id="navSettings" text="Nastavenia" styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="logoutItem" styleClass="nav-item,nav-logout" onMouseClicked="#handleLogout">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="⏻" styleClass="nav-icon,nav-icon-logout" /><Label fx:id="navLogout" text="Odhlásiť" styleClass="nav-label" />
                    </HBox>
                </VBox>
            </VBox>

        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fx:id="mainScroll" fitToWidth="true"
                    styleClass="main-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox styleClass="main-content" spacing="20">

                    <!-- WELCOME BANNER -->
                    <HBox styleClass="welcome-banner" alignment="CENTER_LEFT">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label fx:id="welcomeTitle" text="Vitaj späť 👋" styleClass="welcome-title" />
                            <Label fx:id="welcomeSub"   text="Máš nadchádzajúce termíny tento týždeň."
                                   styleClass="welcome-sub" wrapText="true" />
                        </VBox>
                    </HBox>

                    <!-- SHORTCUT TILES (student) -->
                    <HBox fx:id="studentTilesRow" spacing="16" alignment="CENTER">
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="10"
                              onMouseClicked="#handleCalendar" HBox.hgrow="ALWAYS">
                            <Label text="📅" styleClass="dashboard-tile-icon" />
                            <Label fx:id="tileCalendarText" text="Kalendár"
                                   styleClass="dashboard-tile-title" style="-fx-font-size: 15px;" />
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="10"
                              onMouseClicked="#handleGrades" HBox.hgrow="ALWAYS">
                            <Label text="📊" styleClass="dashboard-tile-icon" />
                            <Label fx:id="tileGradesText" text="Hodnotenia"
                                   styleClass="dashboard-tile-title" style="-fx-font-size: 15px;" />
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="10"
                              onMouseClicked="#handleAlgebra" HBox.hgrow="ALWAYS">
                            <Label text="📝" styleClass="dashboard-tile-icon" />
                            <Label fx:id="tileAssignmentsText" text="Odovzdania"
                                   styleClass="dashboard-tile-title" style="-fx-font-size: 15px;" />
                        </VBox>
                    </HBox>

                    <!-- ADMIN QUICK-LINK TILES (hidden by default, shown for admin) -->
                    <HBox fx:id="adminTilesRow" spacing="16" alignment="CENTER" visible="false" managed="false">
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="10"
                              onMouseClicked="#handleAdminSubjects" HBox.hgrow="ALWAYS">
                            <Label text="📚" styleClass="dashboard-tile-icon" />
                            <Label fx:id="tileAdminSubjectsText" text="Predmety"
                                   styleClass="dashboard-tile-title" style="-fx-font-size: 15px;" />
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="10"
                              onMouseClicked="#handleAdminGuarantors" HBox.hgrow="ALWAYS">
                            <Label text="🔗" styleClass="dashboard-tile-icon" />
                            <Label fx:id="tileAdminGuarantorsText" text="Garanti"
                                   styleClass="dashboard-tile-title" style="-fx-font-size: 15px;" />
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="10"
                              onMouseClicked="#handleAdminCreateTeacher" HBox.hgrow="ALWAYS">
                            <Label text="👤" styleClass="dashboard-tile-icon" />
                            <Label fx:id="tileAdminCreateTeacherText" text="Vytvoriť učiteľa"
                                   styleClass="dashboard-tile-title" style="-fx-font-size: 15px;" />
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="10"
                              onMouseClicked="#handleCalendar" HBox.hgrow="ALWAYS">
                            <Label text="📅" styleClass="dashboard-tile-icon" />
                            <Label fx:id="tileAdminCalendarText" text="Kalendár"
                                   styleClass="dashboard-tile-title" style="-fx-font-size: 15px;" />
                        </VBox>
                    </HBox>

                    <!-- RECENT PERFORMANCE -->
                    <VBox styleClass="section-card" spacing="16">
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="perfTitle" text="Posledné výsledky" styleClass="section-title" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="viewAllPerfText" text="Zobraziť všetky →"
                                   styleClass="link-label" onMouseClicked="#handleGrades"
                                   style="-fx-cursor:hand;" />
                        </HBox>
                        <HBox fx:id="dashboardPerfContainer" spacing="16">
                            <!-- Dynamic performance cards will go here -->
                        </HBox>
                    </VBox>

                    <!-- DEGREE PROGRESS  |  ALERTS  |  UNWIND GAME -->
                    <HBox spacing="16" alignment="TOP_LEFT">

                        <!-- Degree Progress -->
                        <VBox styleClass="section-card" HBox.hgrow="ALWAYS" spacing="16"
                              onMouseClicked="#handleProgress" style="-fx-cursor: hand; -fx-min-width: 260;">
                            <Label fx:id="degreeTitle" text="Progres štúdia" styleClass="section-title" />
                            <Label fx:id="dashboardProgressLabel"
                                   text="Dokončil si 0 z 180 požadovaných kreditov pre Bc. Informatiku."
                                   styleClass="perf-item" wrapText="true" />
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Button fx:id="viewPlanBtn" text="Zobraziť plán"
                                            styleClass="btn-primary" onAction="#handleProgress" />
                                </VBox>
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <StackPane styleClass="progress-ring" minWidth="80" minHeight="80">
                                        <Label fx:id="dashboardProgressPct" text="0%"
                                               styleClass="progress-pct" StackPane.alignment="CENTER" />
                                    </StackPane>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Alerts -->
                        <VBox styleClass="section-card" HBox.hgrow="ALWAYS" spacing="12"
                              onMouseClicked="#handleNotifications" style="-fx-cursor: hand; -fx-min-width: 180;">
                            <Label fx:id="alertsTitle" text="Upozornenia" styleClass="section-title" />
                            <VBox fx:id="dashboardAlertsContainer" spacing="8" />
                        </VBox>

                        <!-- Unwind game -->
                        <VBox styleClass="section-card" spacing="12"
                              style="-fx-min-width: 200; -fx-max-width: 220;">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label fx:id="gameTitleText" text="Odreagovanie" styleClass="section-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="gameScoreLabel" text="0"
                                       style="-fx-text-fill: #06b6d4; -fx-font-weight: bold; -fx-font-size: 16px;" />
                            </HBox>
                            <Pane fx:id="gameArea" minHeight="130" styleClass="game-area">
                                <Button fx:id="gameTarget" text="🎯"
                                        style="-fx-background-color: transparent; -fx-font-size: 26px; -fx-padding: 0; -fx-cursor: hand;" />
                            </Pane>
                        </VBox>

                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
