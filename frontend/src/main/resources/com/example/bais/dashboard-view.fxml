<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root-pane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bais.DashboardController">

    <!-- TOP HEADER -->
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT">
            <HBox styleClass="header-logo-section" alignment="CENTER_LEFT" spacing="10">
                <Label text="🎓" styleClass="header-logo-icon" />
                <VBox spacing="1">
                    <Label fx:id="headerTitle"    text="Akademické Info"   styleClass="header-main-title" />
                    <Label fx:id="headerSubtitle" text="Študentský Portál" styleClass="header-main-subtitle" />
                </VBox>
            </HBox>
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="search-container">
                <TextField fx:id="searchField" promptText="Hľadať AIS Desktop..."
                           styleClass="search-bar" maxWidth="800" />
            </HBox>
            <HBox styleClass="header-actions" alignment="CENTER_RIGHT" spacing="4">
                <StackPane fx:id="notificationsAction" onMouseClicked="#handleNotifications" styleClass="header-action-item">
                    <Label text="🔔" styleClass="notification-icon" />
                    <Label text="3"  styleClass="notification-badge" StackPane.alignment="BOTTOM_RIGHT" />
                </StackPane>
                <Label fx:id="calendarAction" text="📅" styleClass="help-icon" onMouseClicked="#handleCalendar" />
                <Button fx:id="darkModeToggle" text="🌙"
                        styleClass="dark-mode-toggle" onAction="#toggleDarkMode" />
            </HBox>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar">

            <!-- Brand - REMOVED per requirements -->

            <Region styleClass="sidebar-separator" />

            <!-- Main nav -->
            <VBox VBox.vgrow="ALWAYS" spacing="0">
                <VBox fx:id="dashboardItem" styleClass="nav-item,nav-item-active" onMouseClicked="#handleDashboard">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="⊞"  styleClass="nav-icon" /><Label fx:id="navDashboard" text="Prehľad"    styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="gradesItem" styleClass="nav-item" onMouseClicked="#handleGrades">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📊" styleClass="nav-icon" /><Label fx:id="navGrades"    text="Hodnotenia" styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="calendarItem" styleClass="nav-item" onMouseClicked="#handleCalendar">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📅" styleClass="nav-icon" /><Label fx:id="navCalendar"  text="Kalendár"   styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="progressItem" styleClass="nav-item" onMouseClicked="#handleProgress">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="🎓" styleClass="nav-icon" /><Label fx:id="navProgress"  text="Progres"    styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="algebraItem" styleClass="nav-item" onMouseClicked="#handleAlgebra">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📐" styleClass="nav-icon" /><Label fx:id="navAlgebra"   text="Odovzdanie"    styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="coursesItem" styleClass="nav-item" onMouseClicked="#handleCourses">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📚" styleClass="nav-icon" /><Label fx:id="navCourses"   text="Kurzy"      styleClass="nav-label" />
                    </HBox>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- Bottom -->
            <VBox styleClass="sidebar-bottom" spacing="0">
                <VBox fx:id="settingsItem" styleClass="nav-item" onMouseClicked="#handleSettings">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="⚙" styleClass="nav-icon" /><Label fx:id="navSettings" text="Nastavenia" styleClass="nav-label" />
                    </HBox>
                </VBox>
                <VBox fx:id="logoutItem" styleClass="nav-item,nav-logout" onMouseClicked="#handleLogout">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="󰈆" styleClass="nav-icon,nav-icon-logout" /><Label fx:id="navLogout"   text="Odhlásiť"   styleClass="nav-label" />
                    </HBox>
                </VBox>
            </VBox>

        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fx:id="mainScroll" fitToWidth="true"
                    styleClass="main-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox styleClass="main-content" spacing="16">

                    <!-- WELCOME BANNER -->
                    <HBox styleClass="welcome-banner" alignment="CENTER_LEFT">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label fx:id="welcomeTitle" text="Vitaj späť, Adam Novák 👋" styleClass="welcome-title" />
                            <Label fx:id="welcomeSub"   text="Máš 3 nadchádzajúce termíny tento týždeň. Semster je z 74% hotový."
                                   styleClass="welcome-sub" wrapText="true" />
                        </VBox>
                    </HBox>

                    <!-- SHORTCUT TILES -->
                    <HBox spacing="16" alignment="CENTER">
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="8" onMouseClicked="#handleCalendar" HBox.hgrow="ALWAYS">
                            <Label text="◫" styleClass="dashboard-tile-icon" style="-fx-font-size: 32px;" />
                            <Label text="Kalendár" styleClass="dashboard-tile-title" style="-fx-font-size: 16px;" />
                            <VBox fx:id="dashboardMiniCalendar" alignment="CENTER" spacing="4">
                                <!-- Zoznam 2 najbližších udalostí -->
                            </VBox>
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="8" onMouseClicked="#handleNotifications" HBox.hgrow="ALWAYS">
                            <Label text="⚑" styleClass="dashboard-tile-icon" style="-fx-font-size: 32px;" />
                            <Label text="Upozornenia" styleClass="dashboard-tile-title" style="-fx-font-size: 16px;" />
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="8" onMouseClicked="#handleGrades" HBox.hgrow="ALWAYS">
                            <Label text="☆" styleClass="dashboard-tile-icon" style="-fx-font-size: 32px;" />
                            <Label text="Známky" styleClass="dashboard-tile-title" style="-fx-font-size: 16px;" />
                        </VBox>
                        <VBox styleClass="dashboard-tile" alignment="TOP_CENTER" spacing="8" onMouseClicked="#handleAlgebra" HBox.hgrow="ALWAYS">
                            <Label text="✎" styleClass="dashboard-tile-icon" style="-fx-font-size: 32px;" />
                            <Label text="Odovzdania" styleClass="dashboard-tile-title" style="-fx-font-size: 16px;" />
                            <VBox fx:id="dashboardMiniTasks" alignment="CENTER" spacing="4">
                                <!-- Zoznam 2 najbližších zadaní -->
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- RECENT PERFORMANCE -->
                    <VBox styleClass="section-card" spacing="18" onMouseClicked="#handleGrades" style="-fx-cursor: hand;">
                        <HBox alignment="CENTER_LEFT" styleClass="section-header-row">
                            <Label fx:id="perfTitle" text="Výsledky predmetov" styleClass="section-title" HBox.hgrow="ALWAYS" />
                            <Label text="Zobraziť všetky →" styleClass="link-label" />
                        </HBox>
                        <HBox fx:id="dashboardPerfContainer" spacing="20">
                            <!-- Dynamic performance cards will go here -->
                        </HBox>
                    </VBox>

                    <!-- DEGREE PROGRESS + QUICK LINKS -->
                    <HBox spacing="20" alignment="TOP_LEFT">
                        <VBox styleClass="section-card" HBox.hgrow="ALWAYS" spacing="16" onMouseClicked="#handleProgress" style="-fx-cursor: hand;">
                            <Label fx:id="degreeTitle" text="Progres štúdium" styleClass="section-title" />
                            <Label fx:id="dashboardProgressLabel" text="Dokončil si 0 z 180 požadovaných kreditov pre Bc. Informatiku."
                                   styleClass="perf-item" wrapText="true" />
                            <HBox alignment="CENTER_LEFT" spacing="0">
                                <HBox spacing="14">
                                    <Button text="Zobraziť plán" styleClass="btn-primary"  onAction="#handleProgress" />
                                </HBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <StackPane styleClass="progress-ring" minWidth="72" minHeight="72">
                                    <Label fx:id="dashboardProgressPct" text="0%" styleClass="progress-pct" StackPane.alignment="CENTER" />
                                </StackPane>
                            </HBox>
                        </VBox>
                        <VBox styleClass="section-card" spacing="16" minWidth="200" maxWidth="215">
                            <Label fx:id="quickTitle" text="Rýchle odkazy" styleClass="section-title" />
                            <GridPane hgap="12" vgap="12">
                                <VBox styleClass="quick-link-card" alignment="CENTER" spacing="8" onMouseClicked="#handleGrades" style="-fx-cursor: hand;"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0" minWidth="82">
                                    <Label text="📄" styleClass="ql-icon" />
                                    <Label text="Výpis"   styleClass="ql-label" />
                                </VBox>
                                <VBox styleClass="quick-link-card" alignment="CENTER" spacing="8" onMouseClicked="#handleCalendar" style="-fx-cursor: hand;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0" minWidth="82">
                                    <Label text="📅" styleClass="ql-icon" />
                                    <Label text="Skúšky"  styleClass="ql-label" />
                                </VBox>
                                <VBox styleClass="quick-link-card" alignment="CENTER" spacing="8" onMouseClicked="#handleAlgebra" style="-fx-cursor: hand;"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1" minWidth="82">
                                    <Label text="🪪" styleClass="ql-icon" />
                                    <Label text="ISIC"    styleClass="ql-label" />
                                </VBox>
                                <VBox styleClass="quick-link-card" alignment="CENTER" spacing="8" onMouseClicked="#handleCourses" style="-fx-cursor: hand;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="1" minWidth="82">
                                    <Label text="🏫" styleClass="ql-icon" />
                                    <Label text="Kampus"  styleClass="ql-label" />
                                </VBox>
                            </GridPane>
                        </VBox>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
